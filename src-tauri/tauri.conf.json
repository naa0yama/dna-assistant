{
	"$schema": "https://raw.githubusercontent.com/tauri-apps/tauri/dev/crates/tauri-cli/schema.json",
	"productName": "dna-assistant",
	"version": "0.1.12",
	"identifier": "com.naa0yama.dna-assistant",
	"build": {
		"frontendDist": "../ui"
	},
	"app": {
		"withGlobalTauri": true,
		"windows": [
			{
				"title": "DNA Assistant",
				"width": 860,
				"height": 560,
				"minWidth": 640,
				"minHeight": 400,
				"resizable": true
			}
		],
		"security": {
			"csp": null
		}
	},
	"bundle": {
		"active": true,
		"targets": ["nsis"],
		"icon": [
			"icons/32x32.png",
			"icons/128x128.png",
			"icons/128x128@2x.png",
			"icons/icon.ico"
		],
		"windows": {
			"nsis": {
				"displayLanguageSelector": false
			}
		}
	}
}
