{
	"$schema": "https://raw.githubusercontent.com/tauri-apps/tauri/dev/crates/tauri-cli/schema.json",
	"productName": "dna-assistant",
	"version": "0.1.0",
	"identifier": "com.naa0yama.dna-assistant",
	"build": {
		"frontendDist": "../ui"
	},
	"app": {
		"withGlobalTauri": true,
		"windows": [
			{
				"title": "DNA Assistant",
				"width": 420,
				"height": 640,
				"resizable": true
			}
		],
		"security": {
			"csp": null
		}
	},
	"bundle": {
		"active": true,
		"targets": "all",
		"icon": [
			"icons/32x32.png",
			"icons/128x128.png",
			"icons/128x128@2x.png",
			"icons/icon.ico"
		]
	}
}
